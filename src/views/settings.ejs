<%- include('partials/header') %>
<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold"><%= t.settings_title %></h2>
        <p class="text-muted"><%= t.settings_subtitle %></p>
    </div>
</div>

<% if (typeof saved !== 'undefined' && saved === 'true') { %>
<div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
    <strong>Success!</strong> <%= t.success_saved %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<div class="row pb-5">
    <div class="col-md-8 mx-auto">
        
        <!-- WHATSAPP STATUS -->
        <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
            <div class="card-header bg-success text-white py-3 fw-bold">
                <h5 class="mb-0"><i class="fab fa-whatsapp me-2"></i> <%= t.wa_connection %></h5>
            </div>
            <div class="card-body p-4 text-center" id="waStatusContainer">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted mb-0">Checking connection status...</p>
            </div>
        </div>

        <!-- TEST CONNECTION SETTINGS -->
        <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
            <div class="card-header bg-warning text-dark py-3 fw-bold">
                <h5 class="mb-0"><i class="fas fa-vial me-2"></i> <%= t.wa_test %></h5>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small"><%= t.wa_test_desc %></p>
                <div class="input-group mb-2">
                    <span class="input-group-text"><i class="fas fa-phone"></i></span>
                    <input type="text" id="testPhone" class="form-control" placeholder="+31612345678" />
                    <button class="btn btn-primary" type="button" id="btnTestMessage"><%= t.wa_test_btn %></button>
                </div>
                <div id="testMessageAlert"></div>
            </div>
        </div>

        <form action="/settings" method="POST">
            <!-- SCHEDULER SETTINGS -->
            <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-robot me-2"></i> <%= t.automation_title %></h5>
                </div>
                <div class="card-body p-4">
                    <div class="form-check form-switch fs-5 mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="scheduler_enabled" name="scheduler_enabled" value="true" <%= config.scheduler_enabled === 'true' ? 'checked' : '' %>>
                        <label class="form-check-label" for="scheduler_enabled"><%= t.enable_scheduler %></label>
                    </div>
                    <div class="form-check form-switch fs-5 mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="include_age" name="include_age" value="true" <%= config.include_age === 'true' ? 'checked' : '' %>>
                        <label class="form-check-label" for="include_age"><%= t.include_age %></label>
                    </div>
                    
                    <hr class="my-4 opacity-10">
                    
                    <div class="mb-0">
                        <label class="form-label fw-bold"><i class="fas fa-language me-1"></i> <%= t.language_selection %></label>
                        <select name="language" class="form-select">
                            <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English 🇬🇧</option>
                            <option value="nl" <%= currentLang === 'nl' ? 'selected' : '' %>>Nederlands 🇳🇱</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- CARDDAV SETTINGS -->
            <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="fab fa-apple me-2"></i> <%= t.credentials_title %></h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= t.carddav_url %></label>
                        <input type="url" class="form-control" name="carddav_url" value="<%= config.carddav_url %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= t.apple_id %></label>
                        <input type="email" class="form-control" name="carddav_username" value="<%= config.carddav_username %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <%= t.app_password %> 
                            <a href="#" data-bs-toggle="modal" data-bs-target="#appPasswordModal" class="ms-1 text-muted" title="Need help?"><i class="fas fa-question-circle"></i></a>
                        </label>
                        <input type="password" class="form-control" name="carddav_password" value="<%= config.carddav_password %>" placeholder="••••••••••••••" required>
                    </div>
                </div>
            </div>

            <!-- TIME SCHEDULER SETTINGS -->
            <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-clock me-2"></i> <%= t.schedule_title %></h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4"><%= t.schedule_desc %></p>
                    
                    <h6 class="fw-bold"><%= t.weekdays %></h6>
                    <div class="row align-items-center mb-4">
                        <div class="col-md-5">
                            <input type="time" class="form-control" name="weekday_start" value="<%= config.weekday_start %>">
                        </div>
                        <div class="col-md-2 text-center text-muted"><%= t.to %></div>
                        <div class="col-md-5">
                            <input type="time" class="form-control" name="weekday_end" value="<%= config.weekday_end %>">
                        </div>
                    </div>
                    
                    <h6 class="fw-bold"><%= t.weekends %></h6>
                    <div class="row align-items-center mb-3">
                        <div class="col-md-5">
                            <input type="time" class="form-control" name="weekend_start" value="<%= config.weekend_start %>">
                        </div>
                        <div class="col-md-2 text-center text-muted"><%= t.to %></div>
                        <div class="col-md-5">
                            <input type="time" class="form-control" name="weekend_end" value="<%= config.weekend_end %>">
                        </div>
                    </div>
                </div>
            </div>

            <!-- TEMPLATE SETTINGS -->
            <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
                <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-quote-right me-2"></i> <%= t.template_title %></h5>
                    <div>
                        <button type="button" class="btn btn-sm btn-light me-1" id="btnExportTemplates" title="Export templates"><i class="fas fa-file-export me-1"></i> <%= t.btn_export %></button>
                        <label class="btn btn-sm btn-light mb-0" title="Import templates">
                            <i class="fas fa-file-import me-1"></i> <%= t.btn_import %>
                            <input type="file" id="importTemplatesFile" accept=".json" style="display:none;">
                        </label>
                    </div>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small"><%- t.template_desc %></p>
                    
                    <h6 class="fw-bold mt-4"><%= t.with_age %></h6>
                    <textarea class="form-control mb-4" id="templates_with_age" name="templates_with_age" rows="4" required><%= config.templates_with_age %></textarea>

                    <h6 class="fw-bold"><%= t.without_age %></h6>
                    <textarea class="form-control mb-2" id="templates_without_age" name="templates_without_age" rows="4" required><%= config.templates_without_age %></textarea>
                </div>
            </div>

            <!-- EXCLUSION SETTINGS -->
            <div class="card border-0 shadow-sm mb-4 bg-white rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-ban me-2"></i> <%= t.blocklist_title %></h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small"><%= t.blocklist_desc %></p>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="contactSearch" class="form-control" placeholder="<%= t.search_contacts %>" list="contactsDataList">
                        <datalist id="contactsDataList"></datalist>
                    </div>

                    <div id="blockedContainer" class="d-flex flex-wrap gap-2 mb-2">
                        <!-- Blocked pills will appear here -->
                    </div>

                    <!-- Hidden textarea to store the newline-separated list for the form submit -->
                    <textarea id="excluded_contacts_hidden" name="excluded_contacts" style="display:none;"><%= config.excluded_contacts %></textarea>
                </div>
            </div>

            <div class="d-grid mb-5">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm"><i class="fas fa-save me-2"></i> <%= t.save_settings %></button>
            </div>
        </form>
    </div>
</div>

<!-- App-Specific Password Help Modal -->
<div class="modal fade" id="appPasswordModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-dark text-white border-0">
        <h5 class="modal-title"><i class="fab fa-apple me-2"></i> <%= t.apple_help_title %></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <p><%= t.apple_help_desc %></p>
        <ol class="mb-0">
            <li class="mb-2"><%= t.apple_help_step1 %></li>
            <li class="mb-2"><%= t.apple_help_step2 %></li>
            <li class="mb-2"><%= t.apple_help_step3 %></li>
            <li class="mb-2"><%= t.apple_help_step4 %></li>
            <li class="mb-0"><%= t.apple_help_step5 %></li>
        </ol>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal"><%= t.got_it %></button>
      </div>
    </div>
  </div>
</div>

<script>
    document.getElementById('btnTestMessage').addEventListener('click', async () => {
        const phone = document.getElementById('testPhone').value.trim();
        if (!phone) return alert('Please enter a phone number.');

        const btn = document.getElementById('btnTestMessage');
        const alertBox = document.getElementById('testMessageAlert');
        const ogText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        btn.disabled = true;

        try {
            const res = await fetch('/api/test-message', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ phone })
            });
            const data = await res.json();
            
            alertBox.innerHTML = `<div class="alert alert-${data.success ? 'success' : 'danger'} mt-3 mb-0 p-2">
                ${data.success ? 'Test message sent successfully!' : `Error: ${data.error}`}
            </div>`;
        } catch (e) {
            alertBox.innerHTML = `<div class="alert alert-danger mt-3 mb-0 p-2">Request failed. Is your connection down?</div>`;
        } finally {
            btn.innerHTML = ogText;
            btn.disabled = false;
        }
    });
    document.getElementById('btnExportTemplates').addEventListener('click', () => {
        const data = {
            templates_with_age: document.getElementById('templates_with_age').value,
            templates_without_age: document.getElementById('templates_without_age').value
        };
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'birthday-bot-templates.json';
        a.click();
    });

    document.getElementById('importTemplatesFile').addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
            try {
                const data = JSON.parse(ev.target.result);
                if (data.templates_with_age) document.getElementById('templates_with_age').value = data.templates_with_age;
                if (data.templates_without_age) document.getElementById('templates_without_age').value = data.templates_without_age;
                alert('Templates imported successfully! Don\'t forget to click Save Settings.');
            } catch { alert('Invalid JSON file.'); }
        };
        reader.readAsText(file);
        e.target.value = '';
    });
    // Blocklist Management Logic
    let allContacts = [];
    const contactSearch = document.getElementById('contactSearch');
    const contactsDataList = document.getElementById('contactsDataList');
    const blockedContainer = document.getElementById('blockedContainer');
    const hiddenExcluded = document.getElementById('excluded_contacts_hidden');

    const updateHiddenField = () => {
        const pills = blockedContainer.querySelectorAll('.badge [data-val]');
        const values = Array.from(pills).map(p => p.getAttribute('data-val'));
        hiddenExcluded.value = values.join('\n');
    };

    const addBlockedPill = (val) => {
        if (!val) return;
        // Check if already blocked
        const existing = Array.from(blockedContainer.querySelectorAll('[data-val]')).map(p => p.getAttribute('data-val'));
        if (existing.includes(val)) return;

        const pill = document.createElement('div');
        pill.className = 'badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 d-flex align-items-center rounded-pill';
        pill.innerHTML = `<span class="me-2" data-val="${val}">${val}</span>
                          <i class="fas fa-times cursor-pointer remove-blocked" style="cursor:pointer"></i>`;
        
        pill.querySelector('.remove-blocked').onclick = () => {
            pill.remove();
            updateHiddenField();
        };
        
        blockedContainer.appendChild(pill);
        updateHiddenField();
    };

    // Load initial contacts for autocomplete
    const loadContacts = async () => {
        try {
            const res = await fetch('/api/contacts');
            allContacts = await res.json();
            contactsDataList.innerHTML = allContacts.map(c => `<option value="${c.name}">${c.phone}</option>`).join('');
        } catch (e) {
            console.error('Failed to load contacts for blocklist', e);
        }
    };

    contactSearch.addEventListener('input', (e) => {
        const val = e.target.value;
        const match = allContacts.find(c => c.name === val);
        if (match) {
            addBlockedPill(match.name);
            contactSearch.value = '';
        }
    });

    // Handle initial state from DB
    const initBlocklist = () => {
        const initial = hiddenExcluded.value.split('\n').map(s => s.trim()).filter(Boolean);
        initial.forEach(addBlockedPill);
    };

    loadContacts();
                    <p class="small text-muted mt-3 mb-0"><i class="fas fa-sync fa-spin me-1"></i> Waiting for scan...</p>
                `;
                setTimeout(checkWaStatus, 3000);
            } else {
                container.innerHTML = `
                    <div class="spinner-border text-warning mb-2" role="status"></div>
                    <h5 class="fw-bold">Starting WhatsApp Client...</h5>
                    <p class="text-muted mb-0">Please wait. Generating QR code...</p>
                `;
                setTimeout(checkWaStatus, 3000);
            }
        } catch (e) {
            setTimeout(checkWaStatus, 5000);
        }
    }
    checkWaStatus();
</script>

<%- include('partials/footer') %>
