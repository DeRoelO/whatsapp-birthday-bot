<%- include('partials/header') %>
<div class="row">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">Dashboard</h2>
            <p class="text-muted">Overzicht van de Automated WhatsApp Birthday Bot.</p>
        </div>
        <div>
            <button id="btnSync" class="btn btn-outline-primary me-2 shadow-sm"><i class="fas fa-sync-alt me-1"></i> Contacten Syncroniseren</button>
            <button id="btnSend" class="btn btn-primary shadow-sm"><i class="fas fa-paper-plane me-1"></i> Forceer Berichten Vandaag</button>
        </div>
    </div>
</div>

<div id="alertContainer"></div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">WhatsApp Connectie</h6>
                <% if (connected) { %>
                    <div class="display-4 text-success mb-2"><i class="fas fa-check-circle"></i></div>
                    <h5 class="fw-bold">Verbonden</h5>
                <% } else { %>
                    <div class="display-4 text-danger mb-2"><i class="fas fa-times-circle"></i></div>
                    <h5 class="fw-bold">Niet verbonden</h5>
                    <a href="/qr" class="btn btn-sm btn-outline-primary mt-2">Scan QR-code</a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">Totaal Contacten (Sync)</h6>
                <div class="display-4 text-primary mb-2"><i class="fas fa-users"></i></div>
                <h2 class="fw-bold"><%= stats.totalContacts %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">Berichten Verstuurd</h6>
                <div class="display-4 text-info mb-2"><i class="fas fa-paper-plane"></i></div>
                <h2 class="fw-bold"><%= stats.totalMessagesSent %></h2>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('btnSync').addEventListener('click', async () => {
        const btn = document.getElementById('btnSync');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Bezig met syncen...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/sync', { method: 'POST' });
            const data = await res.json();
            
            const alertHtml = `<div class="alert alert-${data.success ? 'success' : 'danger'} alert-dismissible fade show">
                ${data.success ? `Contacten succesvol gesynchroniseerd! (${data.count} up-to-date)` : `Fout bij syncen: ${data.error}`}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            document.getElementById('alertContainer').innerHTML = alertHtml;
            
            if(data.success) setTimeout(() => window.location.reload(), 2000);
        } catch (e) {
            alert('Fout bij commando!');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });

    document.getElementById('btnSend').addEventListener('click', async () => {
        if(!confirm('Weet je zeker dat je geforceerd de jarigen van vandaag wil feliciteren? Let op: ze krijgen misschien dubbele berichtjes als hij later per ongeluk nog draait.')) return;
        
        const btn = document.getElementById('btnSend');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Berichten genereren...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/send-today', { method: 'POST' });
            const data = await res.json();
            
            const alertHtml = `<div class="alert alert-${data.success ? 'success' : 'danger'} alert-dismissible fade show">
                ${data.success ? data.message : `Fout: ${data.error}`}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            document.getElementById('alertContainer').innerHTML = alertHtml;
        } catch (e) {
            alert('Fout bij commando!');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });
</script>

<%- include('partials/footer') %>
