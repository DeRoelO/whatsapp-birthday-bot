<%- include('partials/header') %>
<div class="row">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold"><%= t.dashboard_title %></h2>
            <p class="text-muted text-uppercase small fw-bold"><%= t.dashboard_subtitle %></p>
        </div>
        <div>
            <button id="btnSync" class="btn btn-outline-primary me-2 shadow-sm"><i class="fas fa-sync-alt me-1"></i> <%= t.sync_contacts %></button>
            <button id="btnSend" class="btn btn-primary shadow-sm"><i class="fas fa-paper-plane me-1"></i> <%= t.force_run %></button>
        </div>
    </div>
</div>

<% if (!settings.carddav_username || !settings.carddav_password) { %>
    <div class="alert alert-warning shadow-sm mb-4 border-0">
        <h5>🚀 <%= t.welcome_title %></h5>
        <p class="mb-0"><%= t.welcome_desc %></p>
    </div>
<% } %>

<div id="alertContainer"></div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3"><%= t.wa_connection %></h6>
                <% if (connected) { %>
                    <div class="display-4 text-success mb-2"><i class="fas fa-check-circle"></i></div>
                    <h5 class="fw-bold"><%= t.status_connected %></h5>
                <% } else { %>
                    <div class="display-4 text-danger mb-2"><i class="fas fa-times-circle"></i></div>
                    <h5 class="fw-bold"><%= t.status_disconnected %></h5>
                    <a href="/settings" class="btn btn-sm btn-outline-primary mt-2"><%= t.scan_qr %></a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3"><%= t.stats_contacts %></h6>
                <div class="display-4 text-primary mb-2"><i class="fas fa-users"></i></div>
                <h2 class="fw-bold"><%= stats.totalContacts %></h2>
                <% if (settings.last_sync) { %>
                    <small class="text-muted"><%= t.last_sync %>: <%= new Date(settings.last_sync).toLocaleString(currentLang === 'nl' ? 'nl-NL' : 'en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></small>
                <% } else { %>
                    <small class="text-muted text-uppercase small fw-bold"><%= t.never_sync %></small>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3"><%= t.stats_messages %></h6>
                <div class="display-4 text-info mb-2"><i class="fas fa-paper-plane"></i></div>
                <h2 class="fw-bold"><%= stats.totalMessagesSent %></h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12 mb-3">
        <h4 class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i> <%= t.upcoming_title %></h4>
        <p class="text-muted small"><%= t.upcoming_desc %></p>
    </div>
    <div class="col-12">
        <div class="card border-0 shadow-sm bg-white rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4"><%= t.col_date %></th>
                                <th><%= t.col_name %></th>
                                <th><%= t.col_age %></th>
                                <th><%= t.col_days %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!upcoming || upcoming.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <i class="fas fa-calendar-times mb-2 fa-2x"></i><br>
                                        <%= t.no_birthdays_desc %>
                                    </td>
                                </tr>
                            <% } else { %>
                                <% upcoming.forEach(b => { %>
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <h6 class="mb-0 fw-bold text-primary"><%= b.dateStr %></h6>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; font-weight: bold; font-size: 0.8rem;">
                                                    <%= b.name.charAt(0).toUpperCase() %>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold small"><%= b.name %></h6>
                                                    <% if (b.nickname) { %>
                                                        <small class="text-muted">"<%- b.nickname %>"</small>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (b.age) { %>
                                                <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-1 small"><%= t.turns %> <%= b.age %></span>
                                            <% } else { %>
                                                <span class="text-muted small text-uppercase fw-bold"><%= t.unknown %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (b.daysUntil === 0) { %>
                                                <span class="badge bg-success bg-opacity-10 text-success px-3 py-1 rounded-pill small"><%= t.today %></span>
                                            <% } else if (b.daysUntil === 1) { %>
                                                <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-1 rounded-pill small"><%= t.tomorrow %></span>
                                            <% } else { %>
                                                <span class="text-muted small"><%= t.in_days.replace('[DAYS]', b.daysUntil) %></span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const showAlert = (type, message) => {
        const alertHtml = `<div class="alert alert-${type} alert-dismissible fade show shadow-sm border-0">
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>`;
        document.getElementById('alertContainer').innerHTML = alertHtml;
    };

    document.getElementById('btnSync').addEventListener('click', async () => {
        const btn = document.getElementById('btnSync');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Syncing...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/sync', { method: 'POST' });
            const data = await res.json();
            
            if (data.success) {
                showAlert('success', `<i class="fas fa-check-circle me-1"></i> Contacts successfully synced! Found <strong>${data.count}</strong> contacts with phone numbers.`);
                setTimeout(() => window.location.reload(), 2000);
            } else {
                showAlert('danger', `<i class="fas fa-exclamation-triangle me-1"></i> <strong>Sync Failed:</strong> ${data.error}`);
            }
        } catch (e) {
            showAlert('danger', '<i class="fas fa-bug me-1"></i> Connection error. Is the server running?');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });

    document.getElementById('btnSend').addEventListener('click', async () => {
        if(!confirm('Are you sure you want to forcibly check and send messages right now?')) return;
        
        const btn = document.getElementById('btnSend');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Processing...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/send-today', { method: 'POST' });
            const data = await res.json();
            
            if (data.success) {
                showAlert('success', `<i class="fas fa-paper-plane me-1"></i> ${data.message}`);
                if (data.count > 0) setTimeout(() => window.location.reload(), 3000);
            } else {
                showAlert('danger', `<i class="fas fa-exclamation-triangle me-1"></i> <strong>Error:</strong> ${data.error}`);
            }
        } catch (e) {
            showAlert('danger', '<i class="fas fa-bug me-1"></i> Communication error with the server.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });
</script>

<%- include('partials/footer') %>
