<%- include('partials/header') %>
<div class="row">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">Dashboard</h2>
            <p class="text-muted">Overview of the Automated WhatsApp Birthday Bot.</p>
        </div>
        <div>
            <button id="btnSync" class="btn btn-outline-primary me-2 shadow-sm"><i class="fas fa-sync-alt me-1"></i> Sync Contacts</button>
            <button id="btnSend" class="btn btn-primary shadow-sm"><i class="fas fa-paper-plane me-1"></i> Force Run Today's Birthdays</button>
        </div>
    </div>
</div>

<% if (!settings.carddav_username || !settings.carddav_password) { %>
    <div class="alert alert-warning shadow-sm mb-4 border-0">
        <h5>🚀 Welcome to the WhatsApp Birthday Bot!</h5>
        <p class="mb-0">It looks like no iCloud credentials have been configured yet. Please go to <strong><a href="/settings" class="alert-link">Settings</a></strong> to enter your CardDAV credentials, and then visit <strong><a href="/qr" class="alert-link">WhatsApp</a></strong> to securely link your phone!</p>
    </div>
<% } %>

<div id="alertContainer"></div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">WhatsApp Connection</h6>
                <% if (connected) { %>
                    <div class="display-4 text-success mb-2"><i class="fas fa-check-circle"></i></div>
                    <h5 class="fw-bold">Connected</h5>
                <% } else { %>
                    <div class="display-4 text-danger mb-2"><i class="fas fa-times-circle"></i></div>
                    <h5 class="fw-bold">Disconnected</h5>
                    <a href="/qr" class="btn btn-sm btn-outline-primary mt-2">Scan QR Code</a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">Total Contacts (Synced)</h6>
                <div class="display-4 text-primary mb-2"><i class="fas fa-users"></i></div>
                <h2 class="fw-bold"><%= stats.totalContacts %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-3">Messages Sent</h6>
                <div class="display-4 text-info mb-2"><i class="fas fa-paper-plane"></i></div>
                <h2 class="fw-bold"><%= stats.totalMessagesSent %></h2>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('btnSync').addEventListener('click', async () => {
        const btn = document.getElementById('btnSync');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Syncing...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/sync', { method: 'POST' });
            const data = await res.json();
            
            const alertHtml = `<div class="alert alert-${data.success ? 'success' : 'danger'} alert-dismissible fade show">
                ${data.success ? `Contacts successfully synced! (${data.count} up-to-date)` : `Error syncing: ${data.error}`}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            document.getElementById('alertContainer').innerHTML = alertHtml;
            
            if(data.success) setTimeout(() => window.location.reload(), 2000);
        } catch (e) {
            alert('Command failed!');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });

    document.getElementById('btnSend').addEventListener('click', async () => {
        if(!confirm('Are you sure you want to forcibly send messages to today\\'s birthdays right now? Note: this ignores the time window and might cause double messages if the cron job runs later.')) return;
        
        const btn = document.getElementById('btnSend');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Generating Messages...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/send-today', { method: 'POST' });
            const data = await res.json();
            
            const alertHtml = `<div class="alert alert-${data.success ? 'success' : 'danger'} alert-dismissible fade show">
                ${data.success ? data.message : `Error: ${data.error}`}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            document.getElementById('alertContainer').innerHTML = alertHtml;
        } catch (e) {
            alert('Command failed!');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    });
</script>

<%- include('partials/footer') %>
