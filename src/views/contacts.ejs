<%- include('partials/header') %>

<div class="row">
    <div class="col-12 mb-4">
        <h2 class="fw-bold"><%= t.contacts_title %></h2>
        <p class="text-muted"><%= t.contacts_subtitle %></p>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <ul class="nav nav-tabs card-header-tabs" id="contactTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold" id="suggestions-tab" data-bs-toggle="tab" data-bs-target="#suggestions" type="button"><%= t.tab_suggestions %> <span class="badge bg-primary ms-1"><%= suggestions.length %></span></button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="merges-tab" data-bs-toggle="tab" data-bs-target="#merges" type="button"><%= t.tab_merges %> <span class="badge bg-secondary ms-1"><%= manualMerges.length %></span></button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button"><%= t.tab_all %></button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold text-muted" id="ignored-tab" data-bs-toggle="tab" data-bs-target="#ignored" type="button"><%= t.tab_ignored %> <span class="badge bg-light text-muted border ms-1"><%= ignoredSuggestions.length %></span></button>
                    </li>
                </ul>
            </div>
            <div class="card-body p-4">
                <div class="tab-content" id="contactTabsContent">
                    <!-- Suggestions Tab -->
                    <div class="tab-pane fade show active" id="suggestions" role="tabpanel">
                        <% if (suggestions.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fas fa-magic fa-3x text-muted mb-3 opacity-25"></i>
                                <p class="text-muted"><%= t.no_suggestions %></p>
                            </div>
                        <% } else { %>
                            <div class="list-group list-group-flush">
                                <% suggestions.forEach(s => { %>
                                    <div class="list-group-item border-0 mb-4 bg-light rounded shadow-sm p-4 suggestion-row" id="suggestion-<%= s.id %>">
                                        <div class="row align-items-stretch">
                                            <!-- Contact A -->
                                            <div class="col-md-5">
                                                <div class="p-3 bg-white rounded border h-100">
                                                    <h6 class="mb-1 fw-bold text-primary"><%= s.name_a %></h6>
                                                    <div class="small mb-1"><i class="fas fa-phone fa-fw text-muted me-1"></i> <%= s.phone_a || '<em>No phone</em>' %></div>
                                                    <% if (s.company_a) { %><div class="small mb-1"><i class="fas fa-building fa-fw text-muted me-1"></i> <%= s.company_a %></div><% } %>
                                                    <% if (s.email_a) { %><div class="small mb-1"><i class="fas fa-envelope fa-fw text-muted me-1"></i> <%= s.email_a %></div><% } %>
                                                    <button class="btn btn-sm btn-outline-primary w-100 mt-3" onclick="approveMerge(<%= s.id %>, <%= s.contact_a_id %>, <%= s.contact_b_id %>, true)">
                                                        <%= t.keep_master %> <i class="fas fa-chevron-right ms-1"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            
                                            <!-- VS Separator -->
                                            <div class="col-md-2 d-flex flex-column align-items-center justify-content-center py-3 py-md-0">
                                                <div class="badge bg-secondary mb-2">VS</div>
                                                <i class="fas fa-arrows-left-right fa-2x text-muted opacity-25 d-none d-md-block"></i>
                                                <button class="btn btn-sm btn-link text-danger mt-2" onclick="ignoreSuggestion(<%= s.id %>)"><%= t.ignore %></button>
                                            </div>
                                            
                                            <!-- Contact B -->
                                            <div class="col-md-5">
                                                <div class="p-3 bg-white rounded border h-100">
                                                    <h6 class="mb-1 fw-bold text-success"><%= s.name_b %></h6>
                                                    <div class="small mb-1"><i class="fas fa-phone fa-fw text-muted me-1"></i> <%= s.phone_b || '<em>No phone</em>' %></div>
                                                    <% if (s.company_b) { %><div class="small mb-1"><i class="fas fa-building fa-fw text-muted me-1"></i> <%= s.company_b %></div><% } %>
                                                    <% if (s.email_b) { %><div class="small mb-1"><i class="fas fa-envelope fa-fw text-muted me-1"></i> <%= s.email_b %></div><% } %>
                                                    <button class="btn btn-sm btn-outline-success w-100 mt-3" onclick="approveMerge(<%= s.id %>, <%= s.contact_b_id %>, <%= s.contact_a_id %>, true)">
                                                        <%= t.keep_master %> <i class="fas fa-chevron-right ms-1"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>

                    <!-- Active Merges Tab -->
                    <div class="tab-pane fade" id="merges" role="tabpanel">
                        <% if (manualMerges.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fas fa-link-slash fa-3x text-muted mb-3 opacity-25"></i>
                                <p class="text-muted text-uppercase small fw-bold"><%= t.no_merges %></p>
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th><%= t.col_master %></th>
                                            <th></th>
                                            <th><%= t.col_slave %></th>
                                            <th class="text-end text-uppercase small fw-bold"><%= t.col_action %></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% manualMerges.forEach(m => { %>
                                            <tr>
                                                <td><span class="fw-bold"><%= m.master_name %></span></td>
                                                <td class="text-center text-muted"><i class="fas fa-long-arrow-alt-left"></i></td>
                                                <td><%= m.slave_name %></td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-danger" onclick="unmerge(<%= m.slave_id %>, '<%= m.slave_name %>')">
                                                        <i class="fas fa-unlink me-1 text-uppercase small fw-bold"></i> <%= t.unmerge %>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>

                    <!-- All Contacts Tab -->
                    <div class="tab-pane fade" id="all" role="tabpanel">
                        <div class="input-group mb-4 shadow-sm border rounded">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="contactSearch" class="form-control border-0 py-3" placeholder="<%= t.search_contacts %>" onkeyup="filterContacts()">
                        </div>
                        <div class="list-group list-group-flush" id="contactList">
                            <% allContacts.forEach(c => { %>
                                <div class="list-group-item d-flex justify-content-between align-items-center border-0 mb-1 px-3 py-2 rounded contact-row transition-all">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-secondary text-white text-uppercase" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                            <%= c.name.charAt(0) %>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold"><%= c.name %></h6>
                                            <div class="text-muted small">
                                                <%= c.phone || t.unknown %>
                                                <% if (c.company) { %> • <%= c.company %><% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-muted small d-none d-sm-block">
                                        <% if (c.email) { %><i class="fas fa-envelope me-1"></i> <%= c.email %><% } %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Ignored Tab -->
                    <div class="tab-pane fade" id="ignored" role="tabpanel">
                        <% if (ignoredSuggestions.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fas fa-eye-slash fa-3x text-muted mb-3 opacity-25"></i>
                                <p class="text-muted"><%= t.no_ignored %></p>
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th><%= t.col_contact_a %></th>
                                            <th class="text-center">Link</th>
                                            <th><%= t.col_contact_b %></th>
                                            <th class="text-end text-uppercase small fw-bold"><%= t.col_action %></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% ignoredSuggestions.forEach(s => { %>
                                            <tr id="ignored-<%= s.id %>">
                                                <td>
                                                    <div class="fw-bold"><%= s.name_a %></div>
                                                    <div class="small text-muted"><%= s.phone_a || t.unknown %></div>
                                                </td>
                                                <td class="text-center text-muted"><i class="fas fa-times-circle"></i></td>
                                                <td>
                                                    <div class="fw-bold text-success"><%= s.name_b %></div>
                                                    <div class="small text-muted"><%= s.phone_b || t.unknown %></div>
                                                </td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-link text-primary" onclick="restoreSuggestion(<%= s.id %>)">
                                                        <i class="fas fa-undo me-1"></i> <%= t.restore %>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Danger Zone -->
                <div class="mt-5 pt-5 border-top">
                    <div class="card bg-light border-0">
                        <div class="card-body p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="fw-bold text-danger mb-1 text-uppercase"><%= t.danger_zone %></h6>
                                <p class="small text-muted mb-0"><%= t.danger_desc %></p>
                            </div>
                            <button class="btn btn-outline-danger" onclick="resetDatabase()">
                                <i class="fas fa-trash-alt me-1"></i> <%= t.reset_db %>
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    async function approveMerge(suggestionId, masterId, slaveId) {
        try {
            const res = await fetch('/api/merges', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ masterId, slaveId })
            });
            const data = await res.json();
            if (data.success) {
                const row = document.getElementById(`suggestion-${suggestionId}`);
                row.classList.add('fade-out');
                setTimeout(() => location.reload(), 500);
            } else {
                alert('Error: ' + data.error);
            }
        } catch (err) {
            alert('Error merging: ' + err.message);
        }
    }

    async function ignoreSuggestion(id) {
        try {
            const res = await fetch(`/api/suggestions/${id}/ignore`, { method: 'POST' });
            if (res.ok) {
                const row = document.getElementById(`suggestion-${id}`);
                if (row) row.remove();
                location.reload(); // Reload to update counts and move to ignored tab
            }
        } catch (err) {
            alert('Error ignoring suggestion');
        }
    }

    async function restoreSuggestion(id) {
        try {
            const res = await fetch(`/api/suggestions/${id}/unignore`, { method: 'POST' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Error restoring suggestion');
            }
        } catch (err) {
            alert('Error connecting to server');
        }
    }

    async function unmerge(slaveId, slaveName) {
        const msg = `<%= t.confirm_unmerge %>`.replace('[NAME]', slaveName);
        if (!confirm(msg)) return;
        
        try {
            const res = await fetch(`/api/merges/${slaveId}`, { method: 'DELETE' });
            if (res.ok) location.reload();
        } catch (err) {
            alert('Error unmerging');
        }
    }

    async function resetDatabase() {
        if (!confirm(`<%= t.confirm_reset %>`)) return;
        
        try {
            const res = await fetch('/api/database/reset', { method: 'POST' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Error resetting database');
            }
        } catch (err) {
            alert('Error connecting to server');
        }
    }

    function filterContacts() {
        const val = document.getElementById('contactSearch').value.toLowerCase().trim();
        document.querySelectorAll('.contact-row').forEach(row => {
            const text = row.innerText.toLowerCase();
            if (val === '' || text.includes(val)) {
                row.classList.remove('d-none');
                row.classList.add('d-flex');
            } else {
                row.classList.add('d-none');
                row.classList.remove('d-flex');
            }
        });
    }
</script>

<style>
    .transition-all { transition: all 0.2s ease; }
    .contact-row:hover { background-color: #f8f9fa !important; border-left: 3px solid #198754; padding-left: 17px !important; cursor: default; }
    .nav-tabs .nav-link { border: none; color: #6c757d !important; border-radius: 0; padding: 12px 20px; outline: none !important; box-shadow: none !important; }
    .nav-tabs .nav-link.active { color: #198754 !important; border-bottom: 3px solid #198754 !important; background: none; }
    .fade-out { opacity: 0; transform: scale(0.95); transition: all 0.5s ease; }
    .avatar-circle { font-size: 1.1rem; }
</style>
