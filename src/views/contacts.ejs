<%- include('partials/header') %>

<div class="row">
    <div class="col-12 mb-4">
        <h2 class="fw-bold">Contact Management</h2>
        <p class="text-muted">Manage merge suggestions and manual contact links with extra insight.</p>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <ul class="nav nav-tabs card-header-tabs" id="contactTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold" id="suggestions-tab" data-bs-toggle="tab" data-bs-target="#suggestions" type="button">Suggestions <span class="badge bg-primary ms-1"><%= suggestions.length %></span></button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="merges-tab" data-bs-toggle="tab" data-bs-target="#merges" type="button">Active Merges <span class="badge bg-secondary ms-1"><%= manualMerges.length %></span></button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button">All Contacts</button>
                    </li>
                </ul>
            </div>
            <div class="card-body p-4">
                <div class="tab-content" id="contactTabsContent">
                    <!-- Suggestions Tab -->
                    <div class="tab-pane fade show active" id="suggestions" role="tabpanel">
                        <% if (suggestions.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fas fa-magic fa-3x text-muted mb-3 opacity-25"></i>
                                <p class="text-muted">No new merge suggestions. Everything is clean!</p>
                            </div>
                        <% } else { %>
                            <div class="list-group list-group-flush">
                                <% suggestions.forEach(s => { %>
                                    <div class="list-group-item border-0 mb-4 bg-light rounded shadow-sm p-4 suggestion-row" id="suggestion-<%= s.id %>">
                                        <div class="row align-items-stretch">
                                            <!-- Contact A -->
                                            <div class="col-md-5">
                                                <div class="p-3 bg-white rounded border h-100">
                                                    <h6 class="mb-1 fw-bold text-primary"><%= s.name_a %></h6>
                                                    <div class="small mb-1"><i class="fas fa-phone fa-fw text-muted me-1"></i> <%= s.phone_a || '<em>No phone</em>' %></div>
                                                    <% if (s.company_a) { %><div class="small mb-1"><i class="fas fa-building fa-fw text-muted me-1"></i> <%= s.company_a %></div><% } %>
                                                    <% if (s.email_a) { %><div class="small mb-1"><i class="fas fa-envelope fa-fw text-muted me-1"></i> <%= s.email_a %></div><% } %>
                                                    <button class="btn btn-sm btn-outline-primary w-100 mt-3" onclick="approveMerge(<%= s.id %>, <%= s.contact_a_id %>, <%= s.contact_b_id %>, true)">
                                                        Keep as Master <i class="fas fa-chevron-right ms-1"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            
                                            <!-- VS Separator -->
                                            <div class="col-md-2 d-flex flex-column align-items-center justify-content-center py-3 py-md-0">
                                                <div class="badge bg-secondary mb-2">VS</div>
                                                <i class="fas fa-arrows-left-right fa-2x text-muted opacity-25 d-none d-md-block"></i>
                                                <button class="btn btn-sm btn-link text-danger mt-2" onclick="ignoreSuggestion(<%= s.id %>)">Ignore</button>
                                            </div>
                                            
                                            <!-- Contact B -->
                                            <div class="col-md-5">
                                                <div class="p-3 bg-white rounded border h-100">
                                                    <h6 class="mb-1 fw-bold text-success"><%= s.name_b %></h6>
                                                    <div class="small mb-1"><i class="fas fa-phone fa-fw text-muted me-1"></i> <%= s.phone_b || '<em>No phone</em>' %></div>
                                                    <% if (s.company_b) { %><div class="small mb-1"><i class="fas fa-building fa-fw text-muted me-1"></i> <%= s.company_b %></div><% } %>
                                                    <% if (s.email_b) { %><div class="small mb-1"><i class="fas fa-envelope fa-fw text-muted me-1"></i> <%= s.email_b %></div><% } %>
                                                    <button class="btn btn-sm btn-outline-success w-100 mt-3" onclick="approveMerge(<%= s.id %>, <%= s.contact_b_id %>, <%= s.contact_a_id %>, true)">
                                                        Keep as Master <i class="fas fa-chevron-right ms-1"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>

                    <!-- Active Merges Tab -->
                    <div class="tab-pane fade" id="merges" role="tabpanel">
                        <% if (manualMerges.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="fas fa-link-slash fa-3x text-muted mb-3 opacity-25"></i>
                                <p class="text-muted">No manual merges active yet.</p>
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Master Contact</th>
                                            <th></th>
                                            <th>Merged From (Slave)</th>
                                            <th class="text-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% manualMerges.forEach(m => { %>
                                            <tr>
                                                <td><span class="fw-bold"><%= m.master_name %></span></td>
                                                <td class="text-center text-muted"><i class="fas fa-long-arrow-alt-left"></i></td>
                                                <td><%= m.slave_name %></td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-danger" onclick="unmerge(<%= m.slave_id %>, '<%= m.slave_name %>')">
                                                        <i class="fas fa-unlink me-1"></i> Unmerge
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>

                    <!-- All Contacts Tab -->
                    <div class="tab-pane fade" id="all" role="tabpanel">
                        <div class="input-group mb-4 shadow-sm border rounded">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="contactSearch" class="form-control border-0 py-3" placeholder="Search contact names, phone, company..." onkeyup="filterContacts()">
                        </div>
                        <div class="list-group list-group-flush" id="contactList">
                            <% allContacts.forEach(c => { %>
                                <div class="list-group-item d-flex justify-content-between align-items-center border-0 mb-1 px-3 py-2 rounded contact-row transition-all">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-secondary text-white text-uppercase" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                            <%= c.name.charAt(0) %>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold"><%= c.name %></h6>
                                            <div class="text-muted small">
                                                <%= c.phone || 'No phone' %>
                                                <% if (c.company) { %> • <%= c.company %><% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-muted small d-none d-sm-block">
                                        <% if (c.email) { %><i class="fas fa-envelope me-1"></i> <%= c.email %><% } %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    async function approveMerge(suggestionId, masterId, slaveId) {
        try {
            const res = await fetch('/api/merges', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ masterId, slaveId })
            });
            const data = await res.json();
            if (data.success) {
                const row = document.getElementById(`suggestion-${suggestionId}`);
                row.classList.add('fade-out');
                setTimeout(() => location.reload(), 500);
            } else {
                alert('Error: ' + data.error);
            }
        } catch (err) {
            alert('Error merging: ' + err.message);
        }
    }

    async function ignoreSuggestion(id) {
        try {
            const res = await fetch(`/api/suggestions/${id}/ignore`, { method: 'POST' });
            if (res.ok) {
                const row = document.getElementById(`suggestion-${id}`);
                row.remove();
                if (document.querySelectorAll('.suggestion-row').length === 0) {
                    location.reload();
                }
            }
        } catch (err) {
            alert('Error ignoring suggestion');
        }
    }

    async function unmerge(slaveId, slaveName) {
        if (!confirm(`Are you sure you want to restore "${slaveName}" as a separate contact?`)) return;
        
        try {
            const res = await fetch(`/api/merges/${slaveId}`, { method: 'DELETE' });
            if (res.ok) location.reload();
        } catch (err) {
            alert('Error unmerging');
        }
    }

    function filterContacts() {
        const val = document.getElementById('contactSearch').value.toLowerCase();
        document.querySelectorAll('.contact-row').forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(val) ? 'flex' : 'none';
        });
    }
</script>

<style>
    .transition-all { transition: all 0.2s ease; }
    .contact-row:hover { background-color: #f8f9fa !important; border-left: 3px solid #198754; padding-left: 17px !important; cursor: default; }
    .nav-tabs .nav-link { border: none; color: #6c757d !important; border-radius: 0; padding: 12px 20px; outline: none !important; box-shadow: none !important; }
    .nav-tabs .nav-link.active { color: #198754 !important; border-bottom: 3px solid #198754 !important; background: none; }
    .fade-out { opacity: 0; transform: scale(0.95); transition: all 0.5s ease; }
    .avatar-circle { font-size: 1.1rem; }
</style>
