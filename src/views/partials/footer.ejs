    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <% if (typeof page !== 'undefined' && page === 'qr' && !connected) { %>
    <script>
        setTimeout(() => window.location.reload(), 5000);
    </script>
    <% } %>
</body>
</html>
