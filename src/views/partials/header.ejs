<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Birthday Bot</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom styling -->
    <style>
        body {
            background-color: #f8f9fa;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .nav-link {
            font-weight: 500;
        }
        .nav-link.active {
            font-weight: 700;
            color: #198754 !important;
            border-bottom: 2px solid #198754;
        }
        .stat-card {
            transition: transform 0.2s ease-in-out;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-5 sticky-top">
        <div class="container">
            <a class="navbar-brand text-success d-flex align-items-center" href="/">
                <i class="fab fa-whatsapp fa-2x me-2"></i> Birthday Bot
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item me-2">
                        <a class="nav-link <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>" href="/"><i class="fas fa-home me-1"></i> Dashboard</a>
                    </li>
                    <li class="nav-item me-2">
                        <a class="nav-link <%= typeof page !== 'undefined' && page === 'logs' ? 'active' : '' %>" href="/logs"><i class="fas fa-history me-1"></i> Logs</a>
                    </li>
                    <li class="nav-item me-2">
                        <a class="nav-link <%= typeof page !== 'undefined' && page === 'contacts' ? 'active' : '' %>" href="/contacts"><i class="fas fa-users-cog me-1"></i> Contacts</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof page !== 'undefined' && page === 'settings' ? 'active' : '' %>" href="/settings"><i class="fas fa-cog me-1"></i> Settings</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container pb-5">
